# Server
PORT=3001
NODE_ENV=development

# Discord OAuth2 (create app at https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:3001/auth/discord/callback
SESSION_SECRET=change-me-to-a-random-string

# Database paths
DATABASE_DIR=D:/tdn/databases_backups
APP_DATA_DIR=./data

# Admin configuration (comma-separated Discord user IDs)
ADMIN_DISCORD_IDS=

# Backup configuration
BACKUP_RETENTION_DAYS=30
BACKUP_DEBOUNCE_SECONDS=60

# Base URL (used for CORS and OAuth redirects)
BASE_URL=http://localhost:3001
